# Database Configuration
# For local development with SQLite (no MySQL needed)
DATABASE_URL=sqlite:///./retail_simulator.db
# For MySQL (if you have it installed)
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/retail_simulator

# Application Configuration
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Performance SLA Configuration
RISK_PROCESSING_SLA_SECONDS=300
SIMULATION_SLA_SECONDS=30
UI_RESPONSE_SLA_SECONDS=2

# AWS Configuration (for future use)
AWS_REGION=us-east-1
AWS_BEDROCK_MODEL=anthropic.claude-v2
